# =============================================================================
# wc2026-predictor — what to commit vs ignore
#
# COMMIT:  src/, config/, scripts/, tests/, schema.sql, requirements*.txt,
#          docker-compose.yml, Makefile, README.md, .env.example
#
# IGNORE:  secrets, virtualenvs, scraped/regenerated data, trained models,
#          experiment logs, local DBs, IDE/OS junk
# =============================================================================

# --- Secrets & local env ---
.env
.env.*
!.env.example
*.pem
kaggle.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
*.manifest
*.spec

# Virtual environments (project uses `worldcup/`; also cover common names)
worldcup/
venv/
.venv/
env/
ENV/

# Test / type / lint caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- OS & editors ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# --- Local databases ---
*.db
*.sqlite
*.sqlite3
wc2026.db

# --- ML experiment tracking & trained artifacts ---
mlruns/
mlflow/mlruns/
/models/
backups/
*.pkl
*.pickle
*.joblib
*.onnx
*.pt
*.pth
*.h5
*.ckpt
wandb/
optuna_study.db
lightning_logs/

# --- Logs ---
logs/
*.log

# --- Data (regenerated by scripts/01_collect_all_data.py & 02_build_features.py) ---
# Raw scrapes, processed parquets, and prediction outputs stay local.
data/processed/
data/predictions/

# Ignore all raw data except the hand-maintained WC 2026 schedule.
data/raw/**
!data/raw/schedule/
!data/raw/schedule/**
!data/raw/schedule/wc2026_schedule.json

# --- DVC (if used later) ---
.dvc/
.dvcignore

# --- Playwright / browser automation caches ---
.playwright/
playwright-report/
test-results/

# --- Temporary files ---
tmp/
temp/
*.tmp
*.bak
